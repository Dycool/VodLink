{
  "name": "vodlink-worker",
  "version": "0.1.0",
  "private": true,
  "description": "VodLink session matchmaker: connects friends who streamed the same game at the same time.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute vodlink --file schema.sql",
    "db:init:remote": "wrangler d1 execute vodlink --remote --file schema.sql",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260628.1",
    "typescript": "^5.6.2",
    "wrangler": "^4.105.0"
  }
}
